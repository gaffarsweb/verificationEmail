# Backend socket URL (Render production or local dev)
# Production: https://slot-games-services.onrender.com
# Local dev:  http://localhost:3002
REACT_APP_DH_SOCKET_URL=https://slot-games-services.onrender.com
REACT_APP_CG_SOCKET_URL=https://slot-games-services.onrender.com
REACT_APP_AG_SOCKET_URL=https://slot-games-services.onrender.com

# Test player + game IDs (Mongo ObjectIds)
REACT_APP_DH_PLAYER_ID=<mongo-user-object-id>
REACT_APP_DH_GAME_ID=<duck-hunt-game-object-id>

REACT_APP_CG_PLAYER_ID=<mongo-user-object-id>
REACT_APP_CG_GAME_ID=<celestial-game-object-id>

REACT_APP_AG_PLAYER_ID=<mongo-user-object-id>
REACT_APP_AG_GAME_ID=<agila-game-object-id>
